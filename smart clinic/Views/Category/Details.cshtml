@model smart_clinic.viewmodels.category.ResponseCategoryVM

@{
    ViewData["Title"] = "Category Details";
}

<div class="container mt-4">
    <h2>Category Details</h2>
    <hr />
    <div class="card">
        <div class="card-header bg-info text-white">
            <h4>Category: @Model.cat_name</h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">ID</dt>
                <dd class="col-sm-9">@Model.cat_id</dd>

                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.cat_name</dd>

                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@Model.cat_description</dd>

                <dt class="col-sm-3">Role</dt>
                <dd class="col-sm-9">@Model.role</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @if (Model.isactive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactive</span>
                    }
                </dd>

                <dt class="col-sm-3">Added By</dt>
                <dd class="col-sm-9">@Model.AddedBy</dd>
            </dl>
        </div>
        <div class="card-footer">
            <a asp-action="Edit" asp-route-id="@Model.cat_id" class="btn btn-warning">Edit</a>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</div>