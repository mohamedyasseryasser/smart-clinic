@model smart_clinic.viewmodels.userviewmodel.updatedoctorviewmodel

@{
    ViewData["Title"] = "Update Doctor";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-primary fw-bold">
                        <i class="fas fa-user-edit me-2"></i>Update Doctor: @Model.UserName
                    </h5>
                    <a asp-action="ListDoctors" class="btn btn-outline-secondary btn-sm shadow-sm">
                        <i class="fas fa-arrow-left me-1"></i> Back to List
                    </a>
                </div>
                <div class="card-body p-4">
                    <form asp-action="SaveUpdateDoctor">
                        <div asp-validation-summary="All" class="alert alert-danger mb-4" style="display:none;"></div>
                        <input type="hidden" asp-for="userid" />
                        <input type="hidden" asp-for="DoctorId" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="UserName" class="form-label fw-bold small text-muted text-uppercase"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-user text-primary"></i></span>
                                    <input asp-for="UserName" class="form-control border-start-0 bg-light" />
                                </div>
                                <span asp-validation-for="UserName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label fw-bold small text-muted text-uppercase"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-envelope text-primary"></i></span>
                                    <input asp-for="Email" class="form-control border-start-0 bg-light" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="PhoneNumber" class="form-label fw-bold small text-muted text-uppercase"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-phone text-primary"></i></span>
                                    <input asp-for="PhoneNumber" class="form-control border-start-0 bg-light" />
                                </div>
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Specialization" class="form-label fw-bold small text-muted text-uppercase"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-stethoscope text-primary"></i></span>
                                    <input asp-for="Specialization" class="form-control border-start-0 bg-light" />
                                </div>
                                <span asp-validation-for="Specialization" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Gender" class="form-label fw-bold small text-muted text-uppercase"></label>
                                <select asp-for="Gender" class="form-select bg-light">
                                    <option value="">-- Select Gender --</option>
                                    <option value="1">Male</option>
                                    <option value="2">Female</option>
                                </select>
                                <span asp-validation-for="Gender" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="DepartmentId" class="form-label fw-bold small text-muted text-uppercase"></label>
                                <select asp-for="DepartmentId" asp-items="Model.deptids" class="form-select bg-light">
                                    <option value="">-- Select Department --</option>
                                </select>
                                <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="hiredate" class="form-label fw-bold small text-muted text-uppercase"></label>
                                <input asp-for="hiredate" type="date" class="form-control bg-light" />
                                <span asp-validation-for="hiredate" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="salary" class="form-label fw-bold small text-muted text-uppercase"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-dollar-sign text-primary"></i></span>
                                    <input asp-for="salary" class="form-control border-start-0 bg-light" />
                                </div>
                                <span asp-validation-for="salary" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-4">
                                <label asp-for="address" class="form-label fw-bold small text-muted text-uppercase"></label>
                                <textarea asp-for="address" class="form-control bg-light" rows="2"></textarea>
                                <span asp-validation-for="address" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="submit" class="btn btn-primary px-4 shadow-sm">
                                <i class="fas fa-save me-1"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
