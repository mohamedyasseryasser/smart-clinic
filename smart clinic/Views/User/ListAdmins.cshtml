@model IEnumerable<smart_clinic.viewmodels.userviewmodel.responseadminviewmodel>

@{
    ViewData["Title"] = "Administrators";
}

<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col">
                <h5 class="mb-0 fw-bold">Manage Administrators</h5>
            </div>
            <div class="col-auto">
                <a asp-action="AddAdmin" class="btn btn-primary">
                    <i class="fas fa-plus me-1"></i> Add New Admin
                </a>
            </div>
        </div>
        <hr>
        <form asp-action="ListAdmins" method="get" class="row g-3">
            <div class="col-md-9">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="SearchTerm" class="form-control bg-light border-start-0" placeholder="Search admins..." value="@ViewBag.SearchTerm" />
                </div>
            </div>
            <div class="col-md-3">
                <div class="btn-group w-100">
                    <button type="submit" class="btn btn-secondary">Search</button>
                    <a asp-action="ListAdmins" class="btn btn-outline-secondary">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Admin Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Permissions</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted">#@item.adminid</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                        @(item.UserName?.Substring(0, 1).ToUpper() ?? "A")
                                    </div>
                                    <span class="fw-bold">@item.UserName</span>
                                </div>
                            </td>
                            <td class="small">@item.Email</td>
                            <td>@item.PhoneNumber</td>
                            <td><span class="badge bg-light text-dark border">@item.permissions</span></td>
                            <td>
                                <span class="badge rounded-pill @(item.IsActive ? "bg-success" : "bg-secondary")">
                                    @(item.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a asp-action="UpdateAdmin" asp-route-adminId="@item.adminid" class="btn btn-sm btn-outline-warning"><i class="fas fa-edit"></i></a>
                                    <a asp-action="AdminDetails" asp-route-adminId="@item.adminid" class="btn btn-sm btn-outline-info"><i class="fas fa-eye"></i></a>
                                    <form asp-action="RemoveAdmin" method="post" style="display:inline;" onsubmit="return confirm(\'Are you sure?\');">
                                        <input type="hidden" name="Id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white py-3">
        @{
            var prevDisabled = (ViewBag.PageNumber <= 1) ? "disabled" : "";
            var nextDisabled = (!Model.Any() || Model.Count() < ViewBag.PageSize) ? "disabled" : "";
        }
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                <li class="page-item @prevDisabled">
                    <a class="page-link" asp-action="ListAdmins" asp-route-pageNumber="@(ViewBag.PageNumber - 1)" asp-route-pageSize="@ViewBag.PageSize" asp-route-searchTerm="@ViewBag.SearchTerm">Previous</a>
                </li>
                <li class="page-item disabled"><span class="page-link">Page @ViewBag.PageNumber</span></li>
                <li class="page-item @nextDisabled">
                    <a class="page-link" asp-action="ListAdmins" asp-route-pageNumber="@(ViewBag.PageNumber + 1)" asp-route-pageSize="@ViewBag.PageSize" asp-route-searchTerm="@ViewBag.SearchTerm">Next</a>
                </li>
            </ul>
        </nav>
    </div>
</div>