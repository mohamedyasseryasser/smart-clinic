@model smart_clinic.viewmodels.userviewmodel.responsereceptionistviewmodel

@{
    ViewData["Title"] = "Receptionist Details";
}

<h1>Receptionist Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Username</dt>
        <dd class="col-sm-10">@Model.UserName</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>

        <dt class="col-sm-2">Phone Number</dt>
        <dd class="col-sm-10">@Model.PhoneNumber</dd>

        <dt class="col-sm-2">Address</dt>
        <dd class="col-sm-10">@Model.address</dd>

        <dt class="col-sm-2">Gender</dt>
        <dd class="col-sm-10">@Model.Gender</dd>

        <dt class="col-sm-2">Salary</dt>
        <dd class="col-sm-10">@Model.salary.ToString("C")</dd>

        <dt class="col-sm-2">Hire Date</dt>
        <dd class="col-sm-10">@Model.hiredate.ToLongDateString()</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.status</dd>

        <dt class="col-sm-2">Is Active</dt>
        <dd class="col-sm-10">@(Model.IsActive ? "Yes" : "No")</dd>
    </dl>
</div>
<div>
    <a asp-action="UpdateReceptionist" asp-route-id="@Model.resptionistid" class="btn btn-primary">Edit</a> |
    <a asp-action="ListReceptionists" class="btn btn-secondary">Back to List</a>
</div>