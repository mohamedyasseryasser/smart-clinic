@model smart_clinic.viewmodels.userviewmodel.doctorresponseviewmodel

@{
    ViewData["Title"] = "Doctor Details";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-primary fw-bold">
                <i class="fas fa-user-md me-2"></i>Doctor Details: @Model.UserName
            </h5>
            <div>
                <a asp-action="UpdateDoctor" asp-route-doctorId="@Model.DoctorId" class="btn btn-warning btn-sm shadow-sm">
                    <i class="fas fa-edit me-1"></i> Edit
                </a>
                <a asp-action="ListDoctors" class="btn btn-outline-secondary btn-sm shadow-sm ms-2">
                    <i class="fas fa-arrow-left me-1"></i> Back to List
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4 text-center border-end">
                    <div class="avatar-lg bg-light text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 120px; height: 120px;">
                        <i class="fas fa-user-md fa-4x"></i>
                    </div>
                    <h4 class="fw-bold">@Model.UserName</h4>
                    <p class="text-muted">@Model.Specialization</p>
                    <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger") px-3 py-2 rounded-pill">
                        @(Model.IsActive ? "Active" : "Inactive")
                    </span>
                </div>
                <div class="col-md-8">
                    <h6 class="text-uppercase text-muted small fw-bold mb-3">Professional Information</h6>
                    <div class="row mb-4">
                        <div class="col-sm-6 mb-3">
                            <label class="text-muted small d-block">Department</label>
                            <span class="fw-bold">@Model.deptname</span>
                        </div>
                        <div class="col-sm-6 mb-3">
                            <label class="text-muted small d-block">Hire Date</label>
                            <span class="fw-bold">@Model.hiredate.ToShortDateString()</span>
                        </div>
                        <div class="col-sm-6 mb-3">
                            <label class="text-muted small d-block">Salary</label>
                            <span class="fw-bold text-success">@Model.salary.ToString("C")</span>
                        </div>
                        <div class="col-sm-6 mb-3">
                            <label class="text-muted small d-block">Status</label>
                            <span class="fw-bold">@Model.status</span>
                        </div>
                    </div>

                    <h6 class="text-uppercase text-muted small fw-bold mb-3">Contact Details</h6>
                    <div class="row">
                        <div class="col-sm-6 mb-3">
                            <label class="text-muted small d-block">Email Address</label>
                            <span class="fw-bold">@Model.Email</span>
                        </div>
                        <div class="col-sm-6 mb-3">
                            <label class="text-muted small d-block">Phone Number</label>
                            <span class="fw-bold">@Model.PhoneNumber</span>
                        </div>
                        <div class="col-sm-12 mb-3">
                            <label class="text-muted small d-block">Address</label>
                            <span class="fw-bold">@Model.address</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer bg-light py-3 text-muted small">
            <div class="row">
                <div class="col-sm-6">
                    <i class="fas fa-clock me-1"></i> Created: @Model.createdat.ToString("g")
                </div>
                <div class="col-sm-6 text-sm-end">
                    <i class="fas fa-history me-1"></i> Last Updated: @Model.updatedat.ToString("g")
                </div>
            </div>
        </div>
    </div>
</div>
