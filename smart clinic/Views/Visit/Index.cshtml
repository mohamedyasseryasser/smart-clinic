@model IEnumerable<smart_clinic.viewmodels.Visit.ResponseVisitVM>

@{
    ViewData["Title"] = "Visits List";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-primary fw-bold">
                <i class="fas fa-notes-medical me-2"></i>Visit Management
            </h5>
            <form asp-action="Index" method="get" class="d-flex gap-2">
                <input type="date" name="date" class="form-control form-control-sm"
                       value="@(ViewBag.Date?.ToString("yyyy-MM-dd"))" />
                <button type="submit" class="btn btn-sm btn-primary">Filter</button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Today</a>
            </form>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Patient</th>
                            <th>Date</th>
                            <th>Diagnosis</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var visit in Model)
                            {
                                <tr>
                                    <td class="ps-4 text-muted small">
                                        #@visit.visitid
                                    </td>

                                    <td>
                                        <div class="fw-bold">
                                            @visit.ResponseAppoimentVM?.Patient?.patientname
                                        </div>
                                        <div class="text-muted small">
                                            @visit.ResponseAppoimentVM?.PhoneNumber
                                        </div>
                                    </td>

                                    <td>
                                        <div>@visit.visitdate.ToString("yyyy-MM-dd")</div>
                                        <div class="text-muted small">
                                            @visit.visitdate.ToString("HH:mm")
                                        </div>
                                    </td>

                                    <td>
                                        <span class="text-truncate d-inline-block" style="max-width: 200px;">
                                            @(string.IsNullOrEmpty(visit.diagnosis) ? "---" : visit.diagnosis)
                                        </span>
                                    </td>

                                    <td>
                                        @if (visit.visitstatus == smart_clinic.enums.VisitStatus.InProgress)
                                        {
                                            <span class="badge bg-warning text-dark rounded-pill">
                                                In Progress
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success rounded-pill">
                                                Completed
                                            </span>
                                        }
                                    </td>

                                    <td class="text-end pe-4">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Details"
                                               asp-route-id="@visit.visitid"
                                               class="btn btn-info text-white"
                                               title="View">
                                                <i class="fas fa-eye"></i>
                                            </a>

                                            <a asp-action="Edit"
                                               asp-route-id="@visit.visitid"
                                               class="btn btn-primary"
                                               title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>

                                            @if (visit.visitstatus == smart_clinic.enums.VisitStatus.InProgress)
                                            {
                                                <form asp-action="Complete"
                                                      asp-route-id="@visit.visitid"
                                                      method="post"
                                                      class="d-inline">
                                                    <button type="submit"
                                                            class="btn btn-success"
                                                            title="Complete"
                                                            onclick="return confirm('Complete this visit?')">
                                                        <i class="fas fa-check"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fas fa-info-circle me-2"></i>
                                    No visits found for the selected date
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>