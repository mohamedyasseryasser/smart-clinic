@model IEnumerable<smart_clinic.viewmodels.Visit.ResponseVisitVM>

@{
    ViewData["Title"] = "Visits Management";
}

<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body">

        <div class="row align-items-center">
            <div class="col">
                <h5 class="mb-0 fw-bold">Search Filters</h5>
            </div>
        </div>

        <hr />

        <form method="get" class="row g-3">

            <div class="col-md-4">
                <label class="form-label small fw-bold text-muted">
                    Visit Date
                </label>

                <input type="date"
                       name="date"
                       class="form-control"
                       value="@(ViewBag.Date != null ? ((DateTime)ViewBag.Date).ToString("yyyy-MM-dd") : "")" />
            </div>

            <div class="col-md-2">
                <label class="form-label small fw-bold text-muted">
                    Page Size
                </label>

                <select name="pageSize" class="form-select">
                    <option value="5">5</option>
                    <option value="10" selected>10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-secondary w-100">
                    Filter
                </button>
            </div>

        </form>

    </div>
</div>

<div class="card border-0 shadow-sm">

    <div class="card-body p-0">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Visit ID</th>
                        <th>Patient Name</th>
                        <th>Phone</th>
                        <th>Diagnosis</th>
                        <th>Visit Date</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model != null && Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>

                                <td class="ps-4">
                                    #@item.visitid
                                </td>

                                <td class="fw-bold">
                                    @item.ResponseAppoimentVM?.Patient?.patientname
                                </td>

                                <td>
                                    @item.ResponseAppoimentVM?.Patient?.phonenumber
                                </td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(item.diagnosis)
                                                                ? "No Diagnosis"
                                                                : item.diagnosis)
                                                                             </td>

                                <td>
                                    @item.visitdate.ToString("dd MMM yyyy")
                                </td>

                                <td>
                                    <span class="badge rounded-pill
                                                @(item.visitstatus.ToString() == "Completed"
                                                                                      ? "bg-success"
                                                                                      : item.visitstatus.ToString() == "Pending"
                                                                                          ? "bg-warning text-dark"
                                                                                          : "bg-secondary")">

                                @item.visitstatus

                                    </span>
                                </td>

                                <td class="text-end pe-4">

                                    <div class="btn-group">

                                        <a asp-action="Details"
                                           asp-route-id="@item.visitid"
                                           class="btn btn-sm btn-outline-info"
                                           title="Details">

                                            <i class="fas fa-eye"></i>

                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@item.visitid"
                                           class="btn btn-sm btn-outline-warning"
                                           title="Edit">

                                            <i class="fas fa-edit"></i>

                                        </a>

                                        <form asp-action="Delete"
                                              asp-route-id="@item.visitid"
                                              method="post"
                                              style="display:inline;"
                                              onsubmit="return confirm('Are you sure?')">

                                            @Html.AntiForgeryToken()

                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger"
                                                    title="Delete">

                                                <i class="fas fa-trash"></i>

                                            </button>

                                        </form>

                                    </div>

                                </td>

                            </tr>
                                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7"
                                class="text-center py-5 text-muted">

                                No visits found for this date.

                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>