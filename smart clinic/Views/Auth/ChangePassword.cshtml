@model smart_clinic.viewmodels.Authviewmodel.ChangePasswordViewModel;

@{
    ViewData["Title"] = "Account Settings";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-shield-alt me-2"></i>Security Settings</h5>
            </div>
            <div class="card-body p-4">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="ChangePassword" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3 small"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label small fw-bold text-muted">Email Verification</label>
                        <input asp-for="Email" class="form-control bg-light" placeholder="Enter your registered email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label small fw-bold text-muted">Current Password</label>
                        <input asp-for="Password" type="password" class="form-control bg-light" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <hr class="my-4">

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label small fw-bold text-muted">New Password</label>
                        <input asp-for="NewPassword" type="password" class="form-control bg-light" placeholder="New secure password" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmNewPassword" class="form-label small fw-bold text-muted">Confirm New Password</label>
                        <input asp-for="ConfirmNewPassword" type="password" class="form-control bg-light" placeholder="Repeat new password" />
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                            <i class="fas fa-key me-2"></i> Update Password
                        </button>
                    </div>
                </form>
            </div>
            <div class="card-footer bg-light text-center py-3">
                <p class="mb-0 small text-muted">Having trouble? Contact your administrator.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}