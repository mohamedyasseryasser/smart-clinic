@model smart_clinic.viewmodels.Authviewmodel.LoginViewModel;

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="p-4 p-md-5">
    <div class="text-center mb-4">
        <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
            <i class="fas fa-clinic-medical fa-2x"></i>
        </div>
        <h2 class="fw-bold">Welcome Back</h2>
        <p class="text-muted">Please enter your details to login</p>
    </div>

    <form asp-action="Login" method="post">
        <div asp-validation-summary="All" class="text-danger mb-3 small"></div>

        <div class="form-group mb-3">
            <label asp-for="UserName" class="form-label small fw-bold text-muted">Username</label>
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0"><i class="fas fa-user text-muted"></i></span>
                <input asp-for="UserName" class="form-control bg-light border-start-0" placeholder="Enter your username" />
            </div>
            <span asp-validation-for="UserName" class="text-danger small"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Password" class="form-label small fw-bold text-muted">Password</label>
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0"><i class="fas fa-lock text-muted"></i></span>
                <input asp-for="Password" type="password" class="form-control bg-light border-start-0" placeholder="Enter your password" />
            </div>
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <div class="form-group mb-4 form-check">
            <input asp-for="RememberMe" class="form-check-input" />
            <label asp-for="RememberMe" class="form-check-label text-muted small">Remember me on this device</label>
        </div>

        <div class="form-group d-grid">
            <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm">Sign In</button>
        </div>
    </form>
</div>

<div class="bg-light p-3 text-center border-top">
    <a asp-action="ChangePassword" class="text-decoration-none small fw-medium">Forgot password?</a>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}