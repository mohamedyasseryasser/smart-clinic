@model smart_clinic.viewmodels.Patient.UpdatePatientVM
@using smart_clinic.enums

@{
    ViewData["Title"] = "Edit Patient";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-warning">
                    <h4>Edit Patient: @Model.patientname</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="patientid" />
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="patientname" class="form-label">Full Name</label>
                            <input asp-for="patientname" class="form-control" />
                            <span asp-validation-for="patientname" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="phonenumber" class="form-label">Phone Number</label>
                                <input asp-for="phonenumber" class="form-control" />
                                <span asp-validation-for="phonenumber" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="nationalid" class="form-label">National ID</label>
                                <input asp-for="nationalid" class="form-control" type="number" />
                                <span asp-validation-for="nationalid" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Gender" class="form-label">Gender</label>
                                <select asp-for="Gender" class="form-select" asp-items="Html.GetEnumSelectList<Gender>()"></select>
                                <span asp-validation-for="Gender" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="datebirth" class="form-label">Date of Birth</label>
                                <input asp-for="datebirth" class="form-control" type="date" value="@Model.datebirth.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="datebirth" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="isvalid" class="form-check-input" type="checkbox" />
                            <label asp-for="isvalid" class="form-check-label">Is Active</label>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                            <button type="submit" class="btn btn-warning">Update Patient</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}