@model IEnumerable<smart_clinic.viewmodels.Patient.ResponsePatientVM>

@{
    ViewData["Title"] = "Patients Management";
}

<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col">
                <h5 class="mb-0 fw-bold">Search Filters</h5>
            </div>
            <div class="col-auto">
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus me-1"></i> Add New Patient
                </a>
            </div>
        </div>
        <hr>
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted">Name</label>
                <input type="text" name="name" class="form-control" placeholder="Search by Name" value="@ViewBag.CurrentName">
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted">Phone</label>
                <input type="text" name="phone" class="form-control" placeholder="Search by Phone" value="@ViewBag.CurrentPhone">
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted">National ID</label>
                <input type="number" name="nationalid" class="form-control" placeholder="Search by ID" value="@ViewBag.CurrentNationalId">
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold text-muted">Status</label>
                <select name="isactive" class="form-select">
                    <option value="">All Status</option>
                    <option value="true" selected="@(ViewBag.CurrentIsActive == true)">Active</option>
                    <option value="false" selected="@(ViewBag.CurrentIsActive == false)">Inactive</option>
                </select>
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-secondary w-100">Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Gender</th>
                        <th>Birth Date</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">#@item.patientid</td>
                                <td class="fw-bold">@item.patientname</td>
                                <td>@item.phonenumber</td>
                                <td>@item.Gender</td>
                                <td>@item.datebirth.ToShortDateString()</td>
                                <td>
                                    <span class="badge rounded-pill @(item.isvalid == true ? "bg-success text-white" : "bg-danger text-white")" style="font-size: 0.75rem; padding: 0.35em 0.65em;">
                                        @(item.isvalid == true ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="Details" asp-route-id="@item.patientid" class="btn btn-sm btn-outline-info" title="Details"><i class="fas fa-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@item.patientid" class="btn btn-sm btn-outline-warning" title="Edit"><i class="fas fa-edit"></i></a>
                                        <form asp-action="Delete" asp-route-id="@item.patientid" method="post" onsubmit="return confirm(\'Are you sure?\')" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">No patients found matching your criteria.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>