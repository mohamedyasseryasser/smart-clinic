@model IEnumerable<smart_clinic.viewmodels.Appoinment.ResponseAppoimentVM>

@{
    ViewData["Title"] = "All Appointments";
}

<div class="container-fluid">
    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Appointments for @ViewBag.SelectedDate</h6>
            <form asp-controller="Appoinment" asp-action="ViewAllAppointments" method="get" class="form-inline d-flex">
                <input type="date" name="date" class="form-control me-2" value="@ViewBag.SelectedDate" />
                <button type="submit" class="btn btn-primary">Filter</button>
            </form>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Patient Name</th>
                            <th>Phone Number</th>
                            <th>Date</th>
                            <th>Start At</th>
                            <th>End At</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Patient.patientname</td>
                                <td>@item.PhoneNumber</td>
                                <td>@item.Appoinmentdate.ToShortDateString()</td>
                                <td>@item.startat.ToShortTimeString()</td>
                                <td>@item.endat.ToShortTimeString()</td>
                                <td>
                                    <span class="badge @(item.status == smart_clinic.enums.AppointmentStatus.Completed ? "bg-success" : "bg-warning")">
                                        @item.status
                                    </span>
                                </td>
                                <td>
                                    <a asp-controller="Appoinment" asp-action="Details" asp-route-id="@item.appoimentid" class="btn btn-info btn-sm">Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
