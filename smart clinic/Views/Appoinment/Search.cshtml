@model smart_clinic.viewmodels.Appoinment.SearchAppoinmentVM;

@{
    ViewData["Title"] = "Search Appointments";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-search me-2"></i>Find Appointment</h5>
                    <a asp-action="Create" class="btn btn-sm btn-success">
                        <i class="fas fa-plus me-1"></i> New Appointment
                    </a>
                </div>
            </div>
            <div class="card-body p-4">
                <form method="post" asp-action="Search">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PhoneNumber" class="form-label small fw-bold text-muted">Phone Number</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-phone text-muted"></i></span>
                                <input asp-for="PhoneNumber" class="form-control bg-light border-start-0" placeholder="Enter phone number" />
                            </div>
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Appoinmentdate" class="form-label small fw-bold text-muted">Appointment Date</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-calendar text-muted"></i></span>
                                <input asp-for="Appoinmentdate" type="date" class="form-control bg-light border-start-0" />
                            </div>
                            <span asp-validation-for="Appoinmentdate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="type" class="form-label small fw-bold text-muted">Appointment Type</label>
                            <select asp-for="type" class="form-select bg-light" asp-items="Html.GetEnumSelectList<typeofappoinment>()">
                                <option value="">-- All Types --</option>
                            </select>
                            <span asp-validation-for="type" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label asp-for="state" class="form-label small fw-bold text-muted">Appointment Status</label>
                            <select asp-for="state" class="form-select bg-light" asp-items="Html.GetEnumSelectList<AppointmentStatus>()">
                                <option value="">-- All Statuses --</option>
                            </select>
                            <span asp-validation-for="state" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                            <i class="fas fa-search me-2"></i> Search Appointments
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}