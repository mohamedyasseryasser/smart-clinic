@model smart_clinic.viewmodels.Visit.AddVisit;

@{
    ViewData["Title"] = "Start Visit";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2>Start Visit</h2>

            <div class="card mb-3">
                <div class="card-body">
                    <p><strong>Patient:</strong> @ViewBag.patientname</p>
                    <p><strong>Phone Number:</strong> @ViewBag.PhoNenumber</p>
                    <p><strong>Appointment Date:</strong> @ViewBag.Appoinmentdate.ToString("yyyy-MM-dd")</p>
                </div>
            </div>
            <form method="post" asp-action="CreateVisit" asp-controller="Appoinment">
                <input type="hidden" name="appoinmentid" value="@Model.appoinmentid" />

                <div class="form-group mb-3">
                    <label for="notes" class="form-label">Visit Notes</label>
                    <textarea name="notes" id="notes" class="form-control" rows="3"></textarea>
                </div>

                <div class="form-group mb-3">
                    <label for="diagnosis" class="form-label">Diagnosis</label>
                    <textarea name="diagnosis" id="diagnosis" class="form-control" rows="3"></textarea>
                </div>

                <button type="submit" class="btn btn-primary">Start Visit</button>
                <a href="@Url.Action("Details", new { id = Model.appoinmentid })" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>