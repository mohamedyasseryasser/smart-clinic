@model smart_clinic.viewmodels.Appoinment.AddAppoinmentVM;

@{
    ViewData["Title"] = "Add New Appointment";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2>Add New Appointment</h2>

            <form method="post" asp-action="Create">
                <div asp-validation-summary="All" class="text-danger"></div>
                <div class="form-group mb-3">
                    <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="Enter phone number" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Appoinmentdate" class="form-label">Appointment Date</label>
                    <input asp-for="Appoinmentdate" type="date" class="form-control" />
                    <span asp-validation-for="Appoinmentdate" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="startat" class="form-label">Start Time</label>
                    <input asp-for="startat" type="time" class="form-control" />
                    <span asp-validation-for="startat" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="endat" class="form-label">End Time</label>
                    <input asp-for="endat" type="time" class="form-control" />
                    <span asp-validation-for="endat" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="cost" class="form-label">Cost</label>
                    <input asp-for="cost" type="number" class="form-control" placeholder="Enter cost" />
                    <span asp-validation-for="cost" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="type" class="control-label"></label>
                    <select asp-for="type" class="form-control">
                        <option value="">-- Select type --</option>
                        <option value="1">New</option>
                        <option value="2">FollowUp</option>
                    </select>
                    <span asp-validation-for="type" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="resptionistidid" class="form-label">Receptionist</label>
                    <select asp-items="Model.receptionists" asp-for="resptionistidid" class="form-control">
                        <option value="">Select a receptionist</option>
                        <!-- Populate from database -->
                    </select>
                    <span asp-validation-for="doctorid" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="doctorid" class="form-label">Doctor</label>
                    <select asp-items="Model.doctorsvm" asp-for="doctorid" class="form-control">
                        <option value="">Select a doctor</option>
                        <!-- Populate from database -->
                    </select>
                    <span asp-validation-for="doctorid" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="notes" class="form-label">Notes (Optional)</label>
                    <textarea asp-for="notes" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="notes" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary">Add Appointment</button>
                <a href="@Url.Action("Search")" class="btn btn-secondary">Cancel</a>
             </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}