@model smart_clinic.viewmodels.home.dashboardvm

@{
    ViewData["Title"] = "Clinic Dashboard";
}

<div class="row">
    <div class="col-md-3">
        <div class="card bg-primary text-white shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-1 small fw-bold">Total Patients</h6>
                        <h2 class="mb-0 fw-bold">@Model.patientcount</h2>
                    </div>
                    <div class="icon-shape bg-white text-primary rounded-circle shadow-sm p-3">
                        <i class="fas fa-user-injured fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-success text-white shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-1 small fw-bold">Appointments</h6>
                        <h2 class="mb-0 fw-bold">@Model.appoinmentcount</h2>
                    </div>
                    <div class="icon-shape bg-white text-success rounded-circle shadow-sm p-3">
                        <i class="fas fa-calendar-check fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-info text-white shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-1 small fw-bold">Total Doctors</h6>
                        <h2 class="mb-0 fw-bold">@Model.totaldoctors</h2>
                    </div>
                    <div class="icon-shape bg-white text-info rounded-circle shadow-sm p-3">
                        <i class="fas fa-user-md fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-warning text-white shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-1 small fw-bold">Total Revenue</h6>
                        <h2 class="mb-0 fw-bold">@Model.revenue.ToString("C")</h2>
                    </div>
                    <div class="icon-shape bg-white text-warning rounded-circle shadow-sm p-3">
                        <i class="fas fa-dollar-sign fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Today's Appointments</span>
                <a asp-controller="Appoinment"
                   asp-action="ViewAllAppointments"
                   class="btn btn-sm btn-outline-primary">
                    View All
                </a>
            </div>

            ```
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>Patient</th>
                                <th>Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model.items != null && Model.items.Any())
                            {
                                @foreach (var item in Model.items)
                                {
                                    <tr>
                                        <td>@item.Patient.patientname</td>
                                        <td>@item.Appoinmentdate.ToString("dd/MM/yyyy hh:mm tt")</td>
                                        <td>
                                            <span class="badge bg-success">
                                                @item.status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-3">
                                        No appointments found
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                Quick Actions
            </div>

            <div class="card-body">
                <div class="d-grid gap-2">

                    <a asp-controller="Patient"
                       asp-action="Create"
                       class="btn btn-outline-primary text-start">
                        <i class="fas fa-user-plus me-2"></i>
                        Register New Patient
                    </a>

                    <a asp-controller="Appoinment"
                       asp-action="Create"
                       class="btn btn-outline-success text-start">
                        <i class="fas fa-calendar-plus me-2"></i>
                        Schedule Appointment
                    </a>

                    <a asp-controller="Department"
                       asp-action="Index"
                       class="btn btn-outline-info text-start">
                        <i class="fas fa-hospital me-2"></i>
                        View Departments
                    </a>

                </div>
            </div>
        </div>
    </div>
    ```

</div>
