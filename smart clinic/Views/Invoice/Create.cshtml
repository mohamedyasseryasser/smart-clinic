@using smart_clinic.viewmodels.Invoice
@model createinvoicevm

@{
    ViewData["Title"] = "Create Invoice";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-primary fw-bold">
                        <i class="fas fa-plus-circle me-2"></i>Create New Invoice
                    </h5>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm shadow-sm">
                        <i class="fas fa-arrow-left me-1"></i> Back
                    </a>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" style="display:none;"></div>

                        <div class="mb-3">
                            <label asp-for="VisitId" class="form-label fw-bold small text-muted text-uppercase"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-hashtag text-primary"></i></span>
                                <input asp-for="VisitId" class="form-control border-start-0 bg-light" readonly />
                            </div>
                            <span asp-validation-for="VisitId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="cost" class="form-label fw-bold small text-muted text-uppercase">Visit Base Cost</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-money-bill-wave text-primary"></i></span>
                                <input asp-for="cost" class="form-control border-start-0" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="cost" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Tax" class="form-label fw-bold small text-muted text-uppercase"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-percentage text-primary"></i></span>
                                    <input asp-for="Tax" class="form-control border-start-0" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Tax" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Discount" class="form-label fw-bold small text-muted text-uppercase"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-tag text-primary"></i></span>
                                    <input asp-for="Discount" class="form-control border-start-0" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Discount" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="alert alert-info mt-3 py-2 border-0 shadow-sm">
                            <small><i class="fas fa-info-circle me-1"></i> Final amount will include appointment and prescription costs automatically.</small>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="submit" class="btn btn-primary px-4 shadow-sm">
                                <i class="fas fa-check-circle me-1"></i> Generate Invoice
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
