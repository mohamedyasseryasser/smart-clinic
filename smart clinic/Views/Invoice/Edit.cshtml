@using smart_clinic.viewmodels.Invoice
@model updateinvoicevm

@{
    ViewData["Title"] = "Edit Invoice";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-primary fw-bold">
                        <i class="fas fa-edit me-2"></i>Edit Invoice #@Model.InvoiceId
                    </h5>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm shadow-sm">
                        <i class="fas fa-arrow-left me-1"></i> Back
                    </a>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" style="display:none;"></div>
                        <input type="hidden" asp-for="InvoiceId" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Tax" class="form-label fw-bold small text-muted text-uppercase"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-percentage text-primary"></i></span>
                                    <input asp-for="Tax" class="form-control border-start-0" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Tax" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Discount" class="form-label fw-bold small text-muted text-uppercase"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-tag text-primary"></i></span>
                                    <input asp-for="Discount" class="form-control border-start-0" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Discount" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Status" class="form-label fw-bold small text-muted text-uppercase"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-info-circle text-primary"></i></span>
                                <select asp-for="Status" class="form-select border-start-0 bg-light">
                                    <option value="Pending">Pending</option>
                                    <option value="Paid">Paid</option>
                                    <option value="Cancelled">Cancelled</option>
                                </select>
                            </div>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="submit" class="btn btn-primary px-4 shadow-sm">
                                <i class="fas fa-save me-1"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
