@using smart_clinic.viewmodels.Invoice
@model responseinvoicevm

@{
    ViewData["Title"] = "Invoice Details";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-primary fw-bold">
                        <i class="fas fa-file-invoice me-2"></i>Invoice #@Model.InvoiceId
                    </h5>
                    <div>
                        <a asp-action="Edit" asp-route-id="@Model.InvoiceId" class="btn btn-warning btn-sm shadow-sm">
                            <i class="fas fa-edit me-1"></i> Edit
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm shadow-sm ms-2">
                            <i class="fas fa-arrow-left me-1"></i> Back
                        </a>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-sm-6">
                            <h6 class="text-uppercase text-muted small fw-bold mb-2">Patient Information</h6>
                            <h5 class="fw-bold mb-0">@Model.PatientName</h5>
                            <p class="text-muted">Visit Date: @Model.VisitDate.ToLongDateString()</p>
                        </div>
                        <div class="col-sm-6 text-sm-end">
                            <h6 class="text-uppercase text-muted small fw-bold mb-2">Status</h6>
                            @{
                                var statusClass = Model.Status == "Paid" ? "bg-success text-white" :
                                Model.Status == "Cancelled" ? "bg-danger text-white" :
                                "bg-warning text-dark";
                            }
                            <span class="badge @statusClass px-4 py-2 rounded-pill fs-6">@Model.Status</span>
                            <p class="text-muted mt-2">Issued: @Model.CreatedAt.ToString("g")</p>
                        </div>
                    </div>

                    <div class="table-responsive mb-4">
                        <table class="table table-borderless">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-3">Description</th>
                                    <th class="text-end pe-3">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="ps-3">Appointment Cost</td>
                                    <td class="text-end pe-3 fw-bold">@Model.appoinmentcost.ToString("C")</td>
                                </tr>
                                <tr>
                                    <td class="ps-3">Prescription Items</td>
                                    <td class="text-end pe-3 fw-bold">@Model.prescriptioncost.ToString("C")</td>
                                </tr>
                                <tr class="border-top">
                                    <td class="ps-3 fw-bold">Subtotal</td>
                                    <td class="text-end pe-3 fw-bold">@Model.TotalAmount.ToString("C")</td>
                                </tr>
                                <tr>
                                    <td class="ps-3 text-info">Tax (+)</td>
                                    <td class="text-end pe-3 text-info">@Model.Tax.ToString("C")</td>
                                </tr>
                                <tr>
                                    <td class="ps-3 text-danger">Discount (-)</td>
                                    <td class="text-end pe-3 text-danger">@Model.Discount.ToString("C")</td>
                                </tr>
                            </tbody>
                            <tfoot class="bg-primary text-white">
                                <tr>
                                    <th class="ps-3 py-3 fs-5">Final Total</th>
                                    <th class="text-end pe-3 py-3 fs-5">@Model.FinalAmount.ToString("C")</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
                @if (Model.Status == "Pending")
                {
                    <div class="card-footer bg-light py-3 d-flex justify-content-end gap-2">
                        <form asp-action="Cancel" asp-route-id="@Model.InvoiceId" method="post">
                            <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Cancel this invoice?');">
                                <i class="fas fa-times me-1"></i> Cancel Invoice
                            </button>
                        </form>
                        <form asp-action="Finish" asp-route-id="@Model.InvoiceId" method="post">
                            <button type="submit" class="btn btn-success" onclick="return confirm('Mark as Paid?');">
                                <i class="fas fa-check me-1"></i> Mark as Paid
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
