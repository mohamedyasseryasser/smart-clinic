@model smart_clinic.viewmodels.prescription.ResponsePrescriptionVM

@{
    ViewData["Title"] = "Prescription Details";
}

<div class="container py-4">
    <div class="card shadow-sm border-0" id="printableArea">
        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
            <div>
                <h4 class="mb-0 text-primary fw-bold">Medical Prescription</h4>
                <small class="text-muted">Prescription Date: @Model.prescriptiondate.ToString("yyyy-MM-dd")</small>
            </div>
            <div class="text-end">
                <h5 class="mb-0">#@Model.prescriptionid</h5>
                <span class="badge bg-info">Visit: @Model.visitid</span>
            </div>
        </div>

        <div class="card-body">
            <div class="row mb-4">
                <div class="col-6">
                    <h6 class="text-muted small text-uppercase mb-2">Patient Information</h6>
                    <p class="fw-bold mb-0">@Model.patientname</p>
                    <p class="text-muted small mb-0">Phone: @Model.phonenumber</p>
                </div>

                <div class="col-6 text-end">
                    <h6 class="text-muted small text-uppercase mb-2">Doctor Notes</h6>
                    <p class="mb-0">@(string.IsNullOrEmpty(Model.notes) ? "No General Notes" : Model.notes)</p>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th>Medicine Name</th>
                            <th class="text-center">Quantity</th>
                            <th>Dosage</th>
                            <th>Frequency</th>
                            <th>Duration</th>
                            <th>Notes</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.prescriptionitems)
                        {
                            <tr>
                                <td class="fw-bold">@item.Name</td>
                                <td class="text-center">@item.quantity</td>
                                <td>@item.Dosage</td>
                                <td>@item.Frequency</td>
                                <td>@item.Duration</td>
                                <td class="small">@item.notes</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-5 pt-5 d-flex justify-content-between">
                <div class="text-center border-top pt-2" style="width: 200px;">
                    <small class="text-muted">Clinic Stamp</small>
                </div>

                <div class="text-center border-top pt-2" style="width: 200px;">
                    <small class="text-muted">Doctor Signature</small>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2 no-print">
        <button onclick="window.print()" class="btn btn-secondary">
            <i class="fas fa-print me-1"></i> Print Prescription
        </button>

        <a asp-action="Edit" asp-route-id="@Model.prescriptionid" class="btn btn-primary">
            <i class="fas fa-edit me-1"></i> Edit
        </a>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Back to List
        </a>
    </div>
</div>

<style>
    @@media print {
        .no-print {
            display: none !important;
        }

        body {
            background-color: white !important;
        }

        .card {
            border: none !important;
            box-shadow: none !important;
        }
    }
</style>