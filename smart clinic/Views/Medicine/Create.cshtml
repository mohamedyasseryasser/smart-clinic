@model smart_clinic.viewmodels.medicine.AddMedicineVM

@{
    ViewData["Title"] = "Add Medicine";
}

<div class="container">
    <div class="card shadow mb-4">

        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                Add New Medicine
            </h6>
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="Name" class="form-label"></label>

                        <input asp-for="Name" class="form-control" />

                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">

                        <label asp-for="cat_id" class="form-label">
                            Category
                        </label>

                        <select asp-for="cat_id"
                                class="form-control"
                                asp-items="Model.Categories">
                            <option value="">
                                -- Select Category --
                            </option>
                        </select>

                        <span asp-validation-for="cat_id" class="text-danger"></span>

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-4 mb-3">

                        <label asp-for="StockQuantity" class="form-label">
                            Stock Quantity
                        </label>

                        <input asp-for="StockQuantity"
                               class="form-control"
                               type="number" />

                        <span asp-validation-for="StockQuantity"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label asp-for="UnitPrice" class="form-label">
                            Unit Price
                        </label>

                        <input asp-for="UnitPrice"
                               class="form-control"
                               type="number"
                               step="0.01" />

                        <span asp-validation-for="UnitPrice"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label asp-for="RecordLevel" class="form-label">
                            Reorder Level
                        </label>

                        <input asp-for="RecordLevel"
                               class="form-control"
                               type="number" />

                        <span asp-validation-for="RecordLevel"
                              class="text-danger"></span>

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label asp-for="SupplierName" class="form-label">
                            Supplier Name
                        </label>

                        <input asp-for="SupplierName" class="form-control" />

                        <span asp-validation-for="SupplierName"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label asp-for="ExpiryDate" class="form-label">
                            Expiry Date
                        </label>

                        <input asp-for="ExpiryDate"
                               class="form-control"
                               type="date" />

                        <span asp-validation-for="ExpiryDate"
                              class="text-danger"></span>

                    </div>

                </div>

                <div class="d-flex justify-content-end">

                    <a asp-action="Index"
                       class="btn btn-secondary me-2">

                        Back to List

                    </a>

                    <button type="submit"
                            class="btn btn-primary">

                        Save Medicine

                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}