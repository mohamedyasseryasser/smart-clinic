@model IEnumerable<smart_clinic.viewmodels.medicine.ResponseMedicineVM>

@{
    ViewData["Title"] = "Medicines Management";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-primary fw-bold">
                <i class="fas fa-pills me-2"></i>Medicines Inventory
            </h5>
            <a asp-action="Create" class="btn btn-primary btn-sm shadow-sm">
                <i class="fas fa-plus me-1"></i> Add New Medicine
            </a>
        </div>
        <div class="card-body">
            <!-- Filter Section -->
            <div class="bg-light p-3 rounded mb-4">
                <form method="get" class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-muted text-uppercase">Search</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                            <input type="text" name="searchTerm" class="form-control border-start-0" placeholder="Name or supplier..." value="@ViewBag.SearchTerm" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-muted text-uppercase">Category</label>
                        <select name="cat_id" class="form-select" asp-items="@ViewBag.Categories">
                            <option value="">All Categories</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-muted text-uppercase">Status</label>
                        <select name="isdeleted" class="form-select">
                            <option value="">All Statuses</option>
                            <option value="false" selected="@(ViewBag.isdeleted == false ? "selected" : null)">Active Only</option>
                            <option value="true" selected="@(ViewBag.isdeleted == true ? "selected" : null)">Deleted Only</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-secondary w-100 shadow-sm">
                            <i class="fas fa-filter me-1"></i> Filter
                        </button>
                    </div>
                </form>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="border-0">Medicine Info</th>
                            <th class="border-0">Category</th>
                            <th class="border-0 text-center">Stock</th>
                            <th class="border-0">Price</th>
                            <th class="border-0">Expiry</th>
                            <th class="border-0">Status</th>
                            <th class="border-0 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold text-dark">@item.Name</div>
                                        <div class="small text-muted">Supplier: @item.SupplierName</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-info-soft text-info px-2 py-1">@item.CategoryName</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="fw-bold @(item.StockQuantity < 10 ? "text-danger" : "text-dark")">@item.StockQuantity</div>
                                        @if (item.StockQuantity < 10)
                                        {
                                            <div class="text-danger small" style="font-size: 0.7rem;">Low Stock</div>
                                        }
                                    </td>
                                    <td class="fw-bold text-primary">@item.UnitPrice.ToString("C")</td>
                                    <td>
                                        <div class="small @(item.ExpiryDate < DateTime.Now.AddMonths(3) ? "text-warning" : "text-dark")">
                                            @item.ExpiryDate.ToShortDateString()
                                        </div>
                                    </td>
                                    <td>
                                        @if (item.IsDeleted)
                                        {
                                            <span class="badge bg-danger-soft text-danger">Deleted</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success-soft text-success">Active</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group shadow-sm rounded">
                                            <a asp-action="Details" asp-route-id="@item.medicineId" class="btn btn-white btn-sm border" title="Details">
                                                <i class="fas fa-eye text-info"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.medicineId" class="btn btn-white btn-sm border" title="Edit">
                                                <i class="fas fa-edit text-warning"></i>
                                            </a>
                                            @if (!item.IsDeleted)
                                            {
                                                <form asp-action="Delete" asp-route-id="@item.medicineId" method="post" onsubmit="return confirm('Are you sure?');" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-white btn-sm border" title="Delete">
                                                        <i class="fas fa-trash text-danger"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="fas fa-box-open fa-3x mb-3 d-block"></i>
                                    No medicines found matching your criteria.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-info-soft {
        background-color: rgba(13, 202, 240, 0.1);
    }

    .bg-success-soft {
        background-color: rgba(25, 135, 84, 0.1);
    }

    .bg-danger-soft {
        background-color: rgba(220, 53, 69, 0.1);
    }

    .btn-white {
        background-color: #fff;
        color: #333;
    }

        .btn-white:hover {
            background-color: #f8f9fa;
        }
</style>
